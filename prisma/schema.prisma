generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  imageUrl1   String
  imageUrl2   String?
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaigns CampaignProduct[]
  tags      ProductTag[]
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductTag[]
}

model ProductTag {
  id        String @id @default(cuid())
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@index([productId])
  @@index([tagId])
}

model Campaign {
  id                    String   @id @default(cuid())
  name                  String
  adCount               Int
  status                String   @default("draft")
  targetStoreCategories  Json
  targetAgeMin           Int?
  targetAgeMax           Int?
  targetGender           Json
  targetTags             Json
  targetProductTags      Json     @default("[]")
  targetIncome           Json     @default("[]")
  targetShoppingBehavior Json     @default("[]")
  targetDays             Json     @default("[\"mon\",\"tue\",\"wed\",\"thu\",\"fri\",\"sat\",\"sun\"]")
  targetTimeOfDay        Json     @default("[\"all_day\"]")
  targetWeather          Json     @default("[\"any\"]")
  targetLocations        Json     @default("[]")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  products        CampaignProduct[]
  ideas           CampaignIdea[]
  styles          CampaignStyle[]
  generatedImages GeneratedImage[]
}

model CampaignProduct {
  id         String @id @default(cuid())
  campaignId String
  productId  String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([campaignId, productId])
  @@index([campaignId])
  @@index([productId])
}

model CampaignIdea {
  id          String @id @default(cuid())
  campaignId  String
  description String @db.Text
  sortOrder   Int    @default(0)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model Style {
  id        String   @id @default(cuid())
  name      String   @unique
  prompt    String   @db.Text
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaignStyles CampaignStyle[]
}

model CampaignStyle {
  id         String @id @default(cuid())
  campaignId String
  styleId    String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  style    Style    @relation(fields: [styleId], references: [id], onDelete: Cascade)

  @@unique([campaignId, styleId])
  @@index([campaignId])
  @@index([styleId])
}

model User {
  id                String    @id @default(cuid())
  fullName          String
  username          String    @unique
  email             String?
  passwordHash      String
  role              String    @default("admin")
  isActive          Boolean   @default(true)
  passwordChangedAt DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model GeneratedImage {
  id                     String   @id @default(cuid())
  campaignId             String
  imageUrl               String   @default("")
  replicatePredictionId  String?
  status                 String   @default("pending") // pending, completed, failed
  isDeleted              Boolean  @default(false)
  createdAt              DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}
